<?xml version="1.0" encoding="utf-8"?>
<StartupServicesManifest xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/2011/01/fabric">
  <Parameters>
    <Parameter Name="Gateway_InstanceCount" DefaultValue="-1" />
    <Parameter Name="AuthService_InstanceCount" DefaultValue="-1" />
    <Parameter Name="TravelService_TargetReplicaSetSize" DefaultValue="3" />
    <Parameter Name="TravelService_MinReplicaSetSize" DefaultValue="3" />
    <Parameter Name="BudgetService_InstanceCount" DefaultValue="-1" />
  </Parameters>
  <Services>
    <Service Name="Gateway" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="GatewayType" InstanceCount="[Gateway_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="AuthService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="AuthServiceType" InstanceCount="[AuthService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="TravelService" ServicePackageActivationMode="ExclusiveProcess">
      <StatefulService ServiceTypeName="TravelServiceType" TargetReplicaSetSize="[TravelService_TargetReplicaSetSize]" MinReplicaSetSize="[TravelService_MinReplicaSetSize]">
        <UniformInt64Partition PartitionCount="1" LowKey="0" HighKey="1" />
      </StatefulService>
    </Service>
    <Service Name="BudgetService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="BudgetServiceType" InstanceCount="[BudgetService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
  </Services>
</StartupServicesManifest>