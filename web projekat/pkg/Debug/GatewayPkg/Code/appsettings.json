{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "TravelPlanner_SuperSecretKey_ChangeInProduction_2026!",
    "Issuer": "TravelPlanner.AuthService",
    "Audience": "TravelPlanner.Clients",
    "ExpiryMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "travel-route": {
        "ClusterId": "travel-cluster",
        "Match": {
          "Path": "/api/travel/{**catch-all}"
        }
      },
      "budget-route": {
        "ClusterId": "budget-cluster",
        "Match": {
          "Path": "/api/budget/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:8618/"
          }
        }
      },
      "travel-cluster": {
        "Destinations": {
          "travel": {
            "Address": "http://localhost:8619/"
          }
        }
      },
      "budget-cluster": {
        "Destinations": {
          "budget": {
            "Address": "http://localhost:8620/"
          }
        }
      }
    }
  }
}
